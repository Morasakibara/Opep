# Database
DATABASE_URL=postgresql://opep:opep_dev_secret@localhost:5432/opep_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=opep_jwt_super_secret_change_in_prod_min_32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=opep_refresh_super_secret_change_in_prod
JWT_REFRESH_EXPIRES_IN=7d

# RSA Keys (génération: openssl genrsa -out private.pem 2048)
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# Paiements — MODE DEV (mocks activés)
PAYMENT_MODE=mock   # "mock" | "sandbox" | "live"
STRIPE_SECRET_KEY=sk_test_XXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXX
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_PRIMARY_KEY=mock_mtn_key
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/dev
ORANGE_MONEY_AUTH_HEADER=mock_orange_auth

# Notifications — Africa's Talking
AFRICASTALKING_API_KEY=sandbox_key
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=OPEP
AFRICASTALKING_WHATSAPP_ENABLED=false  # true en production

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@opep.cm
SMTP_PASS=gmail_app_password

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
DEFAULT_LANGUAGE=fr  # "fr" | "en"

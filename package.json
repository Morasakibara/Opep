{
  "name": "opep-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:client": "npm run dev --workspace=apps/client",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "postcss": "^8.5.15",
    "tar": "^7.5.11",
    "uuid": "^11.1.1"
  }
}
